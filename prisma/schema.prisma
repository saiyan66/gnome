generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ────── User 

model User {
  id             String    @id @default(cuid())
  email          String    @unique
  name           String?
  hashedPassword String?                        // nullable because Google OAuth users don't have one
  image          String?                        // profile picture URL from Google
  role           Role      @default(CUSTOMER)
  emailVerified  DateTime?                      // required by NextAuth adapter


  // relations

  accounts  Account[]  // OAuth accounts linked to this user (NextAuth)
  sessions  Session[]  // active sessions (NextAuth)
  orders    Order[]
  cartItems CartItem[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// USER ROLE: admin or not

enum Role {
  CUSTOMER
  ADMIN
}



// ────── NextAuth required models 
// boilerplate required by the Prisma adapter.


model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String  // "google", "credentials", etc.
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}


// ─── Product 

model Product {
  id          String   @id @default(cuid())
  name        String
  slug        String   @unique                // used in URLs: /products/....
  description String   @db.Text
  price       Float
  stock       Int      @default(0)
  category    String
  imageUrl    String?

  // relations
  sustainabilityScore SustainabilityScore?
  cartItems           CartItem[]
  orderItems          OrderItem[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ─── Sustainability Score 

model SustainabilityScore {
  id        String @id @default(cuid())
  productId String @unique       // one-to-one: each product has at most one score

  score  Int                    // 0–100
  reason String @db.Text        // the AI-generated explanation

  product  Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  scoredAt DateTime @default(now())
}

// ─── Cart 

model CartItem {
  id        String @id @default(cuid())
  userId    String
  productId String
  quantity  Int    @default(1)

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  // one user cannot have the same product in cart twice —just increase quantity
  @@unique([userId, productId])
}

// ─── Order 

model Order {
  id              String      @id @default(cuid())
  userId          String
  stripeSessionId String      @unique           // look up a payment by Stripe's ID
  status          OrderStatus @default(PENDING)
  total           Float

  user       User        @relation(fields: [userId], references: [id])
  orderItems OrderItem[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

enum OrderStatus {
  PENDING           // session created, payment not confirmed
  PAID              // webhook confirmed — fulfill the order
  CANCELLED
  REFUNDED
}

// ─── Order Item 

model OrderItem {
  id          String @id @default(cuid())
  orderId     String
  productId   String
  quantity    Int
  priceAtTime Float           // price frozen at checkout time

  order   Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product Product @relation(fields: [productId], references: [id])
}